@page "/counter"

<PageTitle>Counter</PageTitle>

<section class="space-y-4">
    <h1 class="text-3xl font-semibold tracking-tight text-slate-950">Counter</h1>
    <p class="text-slate-700" role="status">Current count: @currentCount</p>
    <button class="rounded-md bg-sky-600 px-4 py-2 font-medium text-white shadow-sm transition hover:bg-sky-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-600" @onclick="IncrementCount">Click me</button>
</section>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }

}
