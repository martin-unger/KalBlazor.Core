@inherits LayoutComponentBase

@* <KalThemeBootstrap /> *@

<KalLayout>
    <KalAppBar Fixed>
        <KalAppBarToggle HorizontalAlignment="KalHorizontalAlignment.Right"/>
        <KalCollapsible HorizontalAlignment="KalHorizontalAlignment.Left">
            <div>Test 1</div>
            <div>Test 2</div>
            <div>Test 3</div>
            <div>Test 4</div>
            <KalDrawerTrigger TargetId="left-menu">
                Links öffnen
            </KalDrawerTrigger>
    
            <KalDrawerTrigger TargetName="right-menu">
                Rechts öffnen
            </KalDrawerTrigger>
    
            <KalThemeToggle>
                Dark Mode
            </KalThemeToggle>
        </KalCollapsible>
    </KalAppBar>
    
    <KalDrawer Id="left-menu"
               Variant="KalDrawerVariant.Docked"
               Backdrop="@_leftDrawerBackdrop"
               Minimizable
               ShowDefaultTrigger="false"
               @bind-InitialState="_leftDrawerState"
               @bind-MinimizeOnClose="_minimizeLeftDrawerOnClose"
               @bind-ExpandOnHover="_expandLeftDrawerOnHover"
               @bind-CollapseOnMouseLeave="_collapseLeftDrawerOnMouseLeave"
               ExpandOnHoverDelay="@_expandOnHoverDelay"
               CollapseOnMouseLeaveDelay="@_collapseOnMouseLeaveDelay"
               PreventClose="@_preventLeftDrawerClose">
        <ChildContent Context="drawer">
            <KalDrawerHeader AdditionalClass="flex items-center justify-between gap-2">
                <KalDrawerMinimizerTrigger AdditionalClass="rounded p-2 hover:bg-slate-100">
                    <KalIcon Icon="@Icons.AngleLeft" />
                </KalDrawerMinimizerTrigger>
                <KalDrawerMaximizerTrigger AdditionalClass="rounded p-2 hover:bg-slate-100">
                    <KalIcon Icon="@Icons.Bars" />
                </KalDrawerMaximizerTrigger>
                <span>Header: @drawer.State</span>
            </KalDrawerHeader>
            <KalDrawerContent>
                <div class="mb-6 flex flex-col gap-3 border-b border-slate-200 pb-6">
                    <label class="flex items-center gap-2">
                        <input type="checkbox" @bind="_preventLeftDrawerClose"/>
                        Schließen verhindern
                    </label>

                    <label class="flex flex-col gap-1">
                        <span>Drawer-Zustand</span>
                        <select class="rounded border border-slate-300 px-2 py-1"
                                @bind="_leftDrawerState">
                            <option value="@KalDrawerState.Hidden">Hidden</option>
                            <option value="@KalDrawerState.Minimized">Minimized</option>
                            <option value="@KalDrawerState.Maximized">Maximized</option>
                        </select>
                    </label>

                    <label class="flex items-center gap-2">
                        <input type="checkbox" @bind="_minimizeLeftDrawerOnClose"/>
                        Beim Schließen minimieren
                    </label>

                    <label class="flex items-center gap-2">
                        <input type="checkbox" @bind="_expandLeftDrawerOnHover"/>
                        Beim Darüberfahren erweitern
                    </label>

                    <label class="flex items-center gap-2">
                        <input type="checkbox" @bind="_collapseLeftDrawerOnMouseLeave"/>
                        Nach Hover wieder schließen
                    </label>

                    <label class="flex flex-col gap-1">
                        <span>Hover-Verzögerung in Millisekunden</span>
                        <input type="number"
                               min="0"
                               class="rounded border border-slate-300 px-2 py-1"
                               @bind="_expandOnHoverDelay"/>
                    </label>

                    <label class="flex flex-col gap-1">
                        <span>Verzögerung beim Verlassen in Millisekunden</span>
                        <input type="number"
                               min="0"
                               class="rounded border border-slate-300 px-2 py-1"
                               @bind="_collapseOnMouseLeaveDelay"/>
                    </label>

                    <label class="flex flex-col gap-1">
                        <span>Hintergrund</span>
                        <select class="rounded border border-slate-300 px-2 py-1"
                                @bind="_leftDrawerBackdrop">
                            <option value="@KalDrawerBackdrop.Darkened">Verdunkelt</option>
                            <option value="@KalDrawerBackdrop.Transparent">Transparent</option>
                            <option value="@KalDrawerBackdrop.None">Deaktiviert</option>
                        </select>
                    </label>

                    <KalDrawerTrigger TargetId="left-menu"
                                      Action="KalDrawerTriggerAction.Close"
                                      AdditionalClass="rounded bg-slate-200 px-3 py-2">
                        Drawer schließen
                    </KalDrawerTrigger>
                </div>

                <div class="flex flex-col gap-3 text-slate-700">
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.AngleDown" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl @(drawer.IsMinimized ? "hidden" : "block")">
                            Angle Down
                        </span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.AngleLeft" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Angle Left</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.AngleRight" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Angle Right</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.AngleUp" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Angle Up</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.ArrowDown" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Arrow Down</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.ArrowLeft" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Arrow Left</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.ArrowRight" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Arrow Right</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.ArrowUp" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Arrow Up</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.Check" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Check</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.Clapperboard" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Clapperboard</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.CircleInfo" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Circle Info</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.Document" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Document</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.ExclamationCircle" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Exclamation Circle</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.FileArrowUp" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">File Arrow Up</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.FileLines" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">File Lines</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.ExcelDocument" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Excel Document</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.Filter" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Filter</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.Graph" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Graph</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.Minus" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Minus</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.Pencil" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Pencil</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.PdfDocument" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Pdf Document</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.Plus" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Plus</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.Printer" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Printer</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.Search" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Search</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.Settings" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Settings</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.TableCells" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Table Cells</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.Trash" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Trash</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.TriangleExclamation" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">Triangle Exclamation</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.UserKey" AdditionalClass="text-xl border-2"/>
                        <span class="text-xl">User Key</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <KalIcon Icon="@Icons.X" AdditionalClass="text-xs border-4"/>
                        <span class="text-xs ">X</span>
                    </div>
                </div>
            </KalDrawerContent>
            <KalDrawerFooter>Footer</KalDrawerFooter>
        </ChildContent>
    </KalDrawer>

    <KalDrawer Name="right-menu" InitialState="KalDrawerState.Hidden" Side="KalDrawerSide.Right" Variant="KalDrawerVariant.Clipped">
        Rechts
    </KalDrawer>

    <KalAppMainContent>
        @Body
        <KalFooterContent>
            <div>Footer content</div>
        </KalFooterContent>
    </KalAppMainContent>
</KalLayout>  

@code {
    private KalDrawerBackdrop _leftDrawerBackdrop = KalDrawerBackdrop.Darkened;
    private KalDrawerState _leftDrawerState = KalDrawerState.Maximized;
    private bool _preventLeftDrawerClose;
    private bool _minimizeLeftDrawerOnClose;
    private bool _expandLeftDrawerOnHover = true;
    private bool _collapseLeftDrawerOnMouseLeave = true;
    private int _expandOnHoverDelay = 500;
    private int _collapseOnMouseLeaveDelay = 300;
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
