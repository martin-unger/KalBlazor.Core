@inherits LayoutComponentBase

@* <KalThemeBootstrap /> *@

<KalLayout>
    <KalAppBar Fixed>
        <KalAppBarToggle HorizontalAlignment="KalHorizontalAlignment.Right"/>
        <KalCollapsible HorizontalAlignment="KalHorizontalAlignment.Left">
            <div>Test 1</div>
            <div>Test 2</div>
            <div>Test 3</div>
            <div>Test 4</div>
            <KalDrawerTrigger TargetId="left-menu">
                Links öffnen
            </KalDrawerTrigger>
    
            <KalDrawerTrigger TargetName="right-menu">
                Rechts öffnen
            </KalDrawerTrigger>
    
            <KalThemeToggle>
                Dark Mode
            </KalThemeToggle>
        </KalCollapsible>
    </KalAppBar>
    
    <KalDrawer Id="left-menu" Variant="KalDrawerVariant.Overlay">
        <KalDrawerHeader>Header</KalDrawerHeader>
        <KalDrawerContent>
            <div class="flex items-center gap-3 text-slate-700">
                <KalIcon Icon="@Icons.Pencil" AdditionalClass="text-xl border-2" />
                <span class="text-xl">Pencil Icon</span>
            </div>
            <div class="flex items-center gap-3 text-slate-700">
                <span class="text-xl">Test</span>
            </div>
        </KalDrawerContent>
        <KalDrawerFooter>Footer</KalDrawerFooter>
    </KalDrawer>

    <KalDrawer Name="right-menu" Side="KalDrawerSide.Right" Variant="KalDrawerVariant.Clipped">
        Rechts
    </KalDrawer>

    <KalAppMainContent>
        @Body
        <KalFooterContent>
            <div>Footer content</div>
        </KalFooterContent>
    </KalAppMainContent>
</KalLayout>  


<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
