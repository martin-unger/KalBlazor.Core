@inherits LayoutComponentBase

@* <KalThemeBootstrap /> *@

<KalLayout>
    <KalAppBar Fixed>
        <KalAppBarToggle HorizontalAlignment="KalHorizontalAlignment.Right"/>
        <KalCollapsible HorizontalAlignment="KalHorizontalAlignment.Left">
            <div>Test 1</div>
            <div>Test 2</div>
            <div>Test 3</div>
            <div>Test 4</div>
            <KalDrawerTrigger TargetId="left-menu">
                Links öffnen
            </KalDrawerTrigger>
    
            <KalDrawerTrigger TargetName="right-menu">
                Rechts öffnen
            </KalDrawerTrigger>
    
            <KalThemeToggle>
                Dark Mode
            </KalThemeToggle>
        </KalCollapsible>
    </KalAppBar>
    
    <KalDrawer Id="left-menu" Variant="KalDrawerVariant.Clipped">
        <KalDrawerHeader>Header</KalDrawerHeader>
        <KalDrawerContent>
            <div class="flex flex-col gap-3 text-slate-700">
                <div class="flex items-center gap-3">
                    <KalIcon Icon="@Icons.AngleDown" AdditionalClass="text-xl border-2" />
                    <span class="text-xl">Angle Down</span>
                </div>
                <div class="flex items-center gap-3">
                    <KalIcon Icon="@Icons.AngleLeft" AdditionalClass="text-xl border-2" />
                    <span class="text-xl">Angle Left</span>
                </div>
                <div class="flex items-center gap-3">
                    <KalIcon Icon="@Icons.AngleRight" AdditionalClass="text-xl border-2" />
                    <span class="text-xl">Angle Right</span>
                </div>
                <div class="flex items-center gap-3">
                    <KalIcon Icon="@Icons.AngleUp" AdditionalClass="text-xl border-2" />
                    <span class="text-xl">Angle Up</span>
                </div>
                <div class="flex items-center gap-3">
                    <KalIcon Icon="@Icons.Clapperboard" AdditionalClass="text-xl border-2" />
                    <span class="text-xl">Clapperboard</span>
                </div>
                <div class="flex items-center gap-3">
                    <KalIcon Icon="@Icons.Document" AdditionalClass="text-xl border-2" />
                    <span class="text-xl">Document</span>
                </div>
                <div class="flex items-center gap-3">
                    <KalIcon Icon="@Icons.FileArrowUp" AdditionalClass="text-xl border-2" />
                    <span class="text-xl">File Arrow Up</span>
                </div>
                <div class="flex items-center gap-3">
                    <KalIcon Icon="@Icons.Filter" AdditionalClass="text-xl border-2" />
                    <span class="text-xl">Filter</span>
                </div>
                <div class="flex items-center gap-3">
                    <KalIcon Icon="@Icons.Pencil" AdditionalClass="text-xl border-2" />
                    <span class="text-xl">Pencil</span>
                </div>
                <div class="flex items-center gap-3">
                    <KalIcon Icon="@Icons.Search" AdditionalClass="text-xl border-2" />
                    <span class="text-xl">Search</span>
                </div>
                <div class="flex items-center gap-3">
                    <KalIcon Icon="@Icons.TableCells" AdditionalClass="text-xl border-2" />
                    <span class="text-xl">Table Cells</span>
                </div>
                <div class="flex items-center gap-3">
                    <KalIcon Icon="@Icons.Trash" AdditionalClass="text-xl border-2" />
                    <span class="text-xl">Trash</span>
                </div>
                <div class="flex items-center gap-3">
                    <KalIcon Icon="@Icons.X" AdditionalClass="text-xs border-4" />
                    <span class="text-xs ">X</span>
                </div>
            </div>
        </KalDrawerContent>
        <KalDrawerFooter>Footer</KalDrawerFooter>
    </KalDrawer>

    <KalDrawer Name="right-menu" Side="KalDrawerSide.Right" Variant="KalDrawerVariant.Clipped">
        Rechts
    </KalDrawer>

    <KalAppMainContent>
        @Body
        <KalFooterContent>
            <div>Footer content</div>
        </KalFooterContent>
    </KalAppMainContent>
</KalLayout>  


<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
