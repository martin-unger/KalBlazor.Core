    private static string GetStatusClass(string status)
    {
        return status switch
        {
            "Aktiv" => "rounded-full bg-emerald-100 px-2 py-1 text-xs font-medium text-emerald-700",
            "Review" => "rounded-full bg-yellow-100 px-2 py-1 text-xs font-medium text-yellow-800",
            _ => "rounded-full bg-rose-100 px-2 py-1 text-xs font-medium text-rose-700"
        };
    }

    private sealed record CustomerAccount(
        string Name,
        string CustomerUrl,
        string Segment,
        string Status,
        string Plan,
        decimal MonthlyRecurringRevenue,
        decimal AnnualRecurringRevenue,
        int Seats,
        int OpenTickets,
        string SupportUrl,
        string Owner,
        string OwnerUrl,
        string Region,
        int ChurnRiskPercent);
