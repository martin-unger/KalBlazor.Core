    private static string GetStatusClass(string status)
    {
        return status switch
        {
            "Aktiv" => "rounded-full bg-emerald-100 px-2 py-1 text-xs font-medium text-emerald-700",
            "Review" => "rounded-full bg-yellow-100 px-2 py-1 text-xs font-medium text-yellow-800",
            _ => "rounded-full bg-rose-100 px-2 py-1 text-xs font-medium text-rose-700"
        };
    }

    private static string GetInvoiceStatusClass(string status)
    {
        return status switch
        {
            "Bezahlt" => "rounded-full bg-emerald-100 px-2 py-1 text-xs font-medium text-emerald-700",
            "Offen" => "rounded-full bg-sky-100 px-2 py-1 text-xs font-medium text-sky-700",
            _ => "rounded-full bg-rose-100 px-2 py-1 text-xs font-medium text-rose-700"
        };
    }

    private sealed record CustomerAccount(
        string Name,
        string CustomerUrl,
        string Segment,
        string Status,
        string Plan,
        decimal MonthlyRecurringRevenue,
        decimal AnnualRecurringRevenue,
        int Seats,
        int OpenTickets,
        string SupportUrl,
        string Owner,
        string OwnerUrl,
        string Region,
        int ChurnRiskPercent,
        IReadOnlyList<CustomerInvoice> Invoices);

    private sealed record CustomerInvoice(
        string Number,
        string Period,
        decimal Amount,
        string Status,
        IReadOnlyList<CustomerInvoiceLine> Lines);

    private sealed record CustomerInvoiceLine(
        string Description,
        int Quantity,
        decimal UnitPrice);
}
