@page "/"
@using SoftwareThingies.KalBlazor.Core.DataGrid

<main class="mx-auto max-w-7xl px-4 py-8">
    <h1 class="mb-6 text-2xl font-semibold text-slate-950">KalDataGrid typed columns</h1>

    <KalDataGrid TItem="CustomerAccount"
                 Items="@Accounts"
                 AdditionalHeaderCellClass="sticky top-[7.25rem] z-20 bg-slate-50"
                 AdditionalClass="my-6">
        <Filter>
            <KalDataGridFilter
                Placeholder="Accounts filtern..."
                AdditionalClass="sticky top-14 z-30" />
        </Filter>

        <Columns>
            <KalToggleGridColumn TItem="CustomerAccount"
                                 HeaderClass="w-24 px-4 py-3"
                                 AdditionalHeaderClass="bg-slate-50 text-slate-900"
                                 CellClass="w-24 px-4 py-3 align-top">
                <CellHeaderTemplate Context="toggle">
                    <button
                        type="button"
                        class="inline-flex items-center rounded-md border border-slate-300 bg-white px-2 py-1 text-xs font-medium text-slate-700 hover:bg-slate-50"
                        aria-expanded="@toggle.AreAllRowsExpanded"
                        aria-label="@toggle.AriaLabel"
                        @onclick="toggle.ToggleAsync">
                        @(toggle.AreAllRowsExpanded ? "Alle zu" : "Alle auf")
                    </button>
                </CellHeaderTemplate>
                <CellTemplate Context="toggle">
                    <button
                        type="button"
                        class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-slate-300 bg-white text-sm font-semibold text-slate-700 hover:bg-amber-50 hover:text-amber-800"
                        aria-expanded="@toggle.IsExpanded"
                        aria-label="@toggle.AriaLabel"
                        @onclick="toggle.ToggleAsync">
                        @(toggle.IsExpanded ? "-" : "+")
                    </button>
                </CellTemplate>
            </KalToggleGridColumn>

            <KalGridColumn TItem="CustomerAccount"
                           Title="Kunde"
                           Property="@(account => account.Name)"
                           WidthClass="w-[18rem]"
                           AdditionalHeaderClass="bg-amber-50 text-amber-900">
                <CellHeaderTemplate>
                    <div>Kunde</div>
                    <div class="text-[0.65rem] font-normal normal-case tracking-normal text-amber-700">
                        Name und Segment
                    </div>
                </CellHeaderTemplate>
                <CellTemplate Context="account">
                    <a href="@account.CustomerUrl"
                       class="font-semibold text-amber-700 hover:text-amber-900 hover:underline">
                        @account.Name
                    </a>
                    <div class="text-xs text-slate-500">@account.Segment</div>
                </CellTemplate>
                <CollapsedContent Context="account">
                    <div>Status: @account.Status</div>
                    <div>Plan: @account.Plan</div>
                    <div>Seats: @account.Seats</div>
                    <div>Tickets: <a href="@account.SupportUrl" class="text-amber-700 hover:underline">@account.OpenTickets offen</a></div>
                    <div>Owner: <a href="@account.OwnerUrl" class="text-amber-700 hover:underline">@account.Owner</a></div>
                    <div>Region: @account.Region</div>
                    <div>MRR: @account.MonthlyRecurringRevenue.ToString("N0") EUR</div>
                    <div>ARR: @account.AnnualRecurringRevenue.ToString("N0") EUR</div>
                    <div>Churn Risk: @account.ChurnRiskPercent%</div>
                </CollapsedContent>
            </KalGridColumn>

            <KalGridColumn TItem="CustomerAccount"
                           Title="Status"
                           Property="@(account => account.Status)"
                           CollapseBelow="KalDataGridBreakpoint.Md"
                           AdditionalHeaderClass="bg-amber-50 text-amber-900">
                <CellTemplate Context="account">
                    <span class="@GetStatusClass(account.Status)">@account.Status</span>
                </CellTemplate>
            </KalGridColumn>

            <KalGridColumn TItem="CustomerAccount"
                           Title="Plan"
                           Property="@(account => account.Plan)"
                           CollapseBelow="KalDataGridBreakpoint.Lg" />

            <KalGridColumn TItem="CustomerAccount"
                           Title="MRR"
                           Property="@(account => account.MonthlyRecurringRevenue)"
                           Alignment="KalDataGridAlignment.End">
                <CellTemplate Context="account">
                    @account.MonthlyRecurringRevenue.ToString("N0") EUR
                </CellTemplate>
            </KalGridColumn>

            <KalGridColumn TItem="CustomerAccount"
                           Title="Seats"
                           Property="@(account => account.Seats)"
                           Alignment="KalDataGridAlignment.End"
                           CollapseBelow="KalDataGridBreakpoint.Md" />

            <KalGridColumn TItem="CustomerAccount"
                           Title="Tickets"
                           Property="@(account => account.OpenTickets)"
                           Alignment="KalDataGridAlignment.End"
                           CollapseBelow="KalDataGridBreakpoint.Lg">
                <CellTemplate Context="account">
                    <a href="@account.SupportUrl" class="text-amber-700 hover:underline">
                        @account.OpenTickets
                    </a>
                </CellTemplate>
            </KalGridColumn>

            <KalGridColumn TItem="CustomerAccount"
                           Title="Owner"
                           Property="@(account => account.Owner)"
                           CollapseBelow="KalDataGridBreakpoint.Xl">
                <CellTemplate Context="account">
                    <a href="@account.OwnerUrl" class="text-amber-700 hover:underline">
                        @account.Owner
                    </a>
                </CellTemplate>
            </KalGridColumn>

            <KalGridColumn TItem="CustomerAccount"
                           Title="Region"
                           Property="@(account => account.Region)"
                           CollapseBelow="KalDataGridBreakpoint.Xl" />

            <KalGridColumn TItem="CustomerAccount"
                           Title="ARR"
                           Property="@(account => account.AnnualRecurringRevenue)"
                           Alignment="KalDataGridAlignment.End"
                           CollapseBelow="KalDataGridBreakpoint.TwoXl">
                <CellTemplate Context="account">
                    @account.AnnualRecurringRevenue.ToString("N0") EUR
                </CellTemplate>
            </KalGridColumn>

            <KalGridColumn TItem="CustomerAccount"
                           Title="Churn Risk"
                           Property="@(account => account.ChurnRiskPercent)"
                           Alignment="KalDataGridAlignment.End"
                           CollapseBelow="KalDataGridBreakpoint.TwoXl">
                <CellTemplate Context="account">
                    @account.ChurnRiskPercent%
                </CellTemplate>
            </KalGridColumn>
        </Columns>

        <ChildRowContent Context="account">
            <KalDataGrid TItem="CustomerInvoice"
                         Items="@account.Invoices"
                         TableClass="w-full min-w-full border-collapse text-xs"
                         HeaderClass="bg-slate-100"
                         BodyClass="divide-y divide-slate-200"
                         RowClass="transition-colors hover:bg-slate-50">
                <Columns>
                    <KalGridColumn TItem="CustomerInvoice"
                                   Title="Rechnung"
                                   Property="@(invoice => invoice.Number)" />
                    <KalGridColumn TItem="CustomerInvoice"
                                   Title="Zeitraum"
                                   Property="@(invoice => invoice.Period)"
                                   CollapseBelow="KalDataGridBreakpoint.Md" />
                    <KalGridColumn TItem="CustomerInvoice"
                                   Title="Betrag"
                                   Property="@(invoice => invoice.Amount)"
                                   Alignment="KalDataGridAlignment.End">
                        <CellTemplate Context="invoice">
                            @invoice.Amount.ToString("N0") EUR
                        </CellTemplate>
                    </KalGridColumn>
                    <KalGridColumn TItem="CustomerInvoice"
                                   Title="Status"
                                   Property="@(invoice => invoice.Status)"
                                   Alignment="KalDataGridAlignment.End">
                        <CellTemplate Context="invoice">
                            <span class="@GetInvoiceStatusClass(invoice.Status)">@invoice.Status</span>
                        </CellTemplate>
                    </KalGridColumn>
                </Columns>

                <ChildRowContent Context="invoice">
                    <div class="grid gap-2 text-xs text-slate-600 md:grid-cols-2">
                        @foreach (var line in invoice.Lines)
                        {
                            <div class="rounded-md border border-slate-200 bg-white px-3 py-2">
                                <div class="font-medium text-slate-900">@line.Description</div>
                                <div>@line.Quantity x @line.UnitPrice.ToString("N0") EUR</div>
                            </div>
                        }
                    </div>
                </ChildRowContent>
            </KalDataGrid>
        </ChildRowContent>
    </KalDataGrid>
</main>

