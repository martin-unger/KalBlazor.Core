@namespace SoftwareThingies.KalBlazor.Core
@inherits BaseComponent

<span @attributes="FilteredAdditionalAttributes" class="@CssClass" aria-hidden="true">
    @if (ChildContent is null)
    {
        <span class="relative h-6 w-6">
            <span class="absolute left-0 top-1/2 block h-1 w-6 -translate-y-1/2 rotate-45 bg-current"></span>
            <span class="absolute left-0 top-1/2 block h-1 w-6 -translate-y-1/2 -rotate-45 bg-current"></span>
        </span>
    }
    else
    {
        @ChildContent
    }
</span>
