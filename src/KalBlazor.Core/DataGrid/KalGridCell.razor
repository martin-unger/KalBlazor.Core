@namespace SoftwareThingies.KalBlazor.Core.DataGrid
@inherits BaseComponent

<td @attributes="FilteredAdditionalAttributes" class="@CssClass">
    @ChildContent

    @if (CollapsedContent is not null)
    {
        <div class="@CollapsedContentCssClass">
            @CollapsedContent
        </div>
    }
</td>
